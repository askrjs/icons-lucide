{
  "name": "@askrjs/askr-lucide",
  "version": "0.0.1",
  "description": "Thin Askr wrappers for the Lucide SVG icon set",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/askrjs/askr-lucide.git"
  },
  "homepage": "https://github.com/askrjs/askr-lucide#readme",
  "bugs": {
    "url": "https://github.com/askrjs/askr-lucide/issues"
  },
  "author": {
    "name": "askrjs",
    "url": "https://github.com/askrjs"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "askr",
    "askrjs",
    "icons",
    "lucide",
    "svg",
    "components"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons/*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@askrjs/askr": "0.0.1"
  },
  "devDependencies": {
    "@askrjs/askr": "file:../askr",
    "jsdom": "^29.0.1",
    "lucide": "latest",
    "typescript": "^5.0.0",
    "vite-plus": "latest"
  },
  "scripts": {
    "generate": "node scripts/generate.js",
    "build": "npm run generate && vp build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "vp build --watch",
    "test": "vp test run",
    "test:types": "npm run generate && tsc -p tsconfig.build.json --noEmit",
    "fmt": "vp fmt .",
    "lint": "vp fmt --check ."
  }
}
